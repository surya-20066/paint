<!DOCTYPE html>
<html class="light" lang="en">
<head>
<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<title>The Painted Muse</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="components/Navbar.js" defer></script>
<script src="components/Footer.js" defer></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
rel="stylesheet" />
<style>
body {
font-family: 'Inter', sans-serif;
background-color: #f8f9fc;
background-image:
radial-gradient(circle at 50% 50%, rgba(79, 55, 138, 0.04), transparent),
radial-gradient(1px 1px at 20px 30px, #4f378a11, transparent);
}
.success-glow {
box-shadow: 0 0 40px 0 rgba(79, 55, 138, 0.15);
}
</style>
</head>
<body class="min-h-screen flex flex-col justify-between">
<app-navbar></app-navbar>
<main class="max-w-xl w-full mx-auto p-6 my-auto">
<div class="bg-white rounded-3xl p-8 border border-slate-100 success-glow text-center space-y-6">
<div
class="w-24 h-24 bg-green-50 rounded-full flex items-center justify-center mx-auto text-green-600 shadow-inner">
<span class="material-symbols-outlined text-5xl font-bold"
style="font-variation-settings: 'FILL' 0;">check</span>
</div>
<div class="space-y-2">
<h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Booking Confirmed!</h1>
<p class="text-slate-500 text-sm">Your order is received. We'll verify your UPI payment and confirm within 30 minutes.</p>
</div>
<hr class="border-slate-100" />
<div class="bg-slate-50 p-6 rounded-2xl text-left space-y-3 text-sm text-slate-600">
<div class="flex justify-between">
<span>Product Purchased:</span>
<span class="font-semibold text-slate-800" id="product-name">Celestial Membership - Premium Annual</span>
</div>
<div class="flex justify-between">
<span>Total Amount Charged:</span>
<span class="font-bold text-indigo-700" id="product-amount">$1,308.50 USD</span>
</div>
<div class="flex justify-between">
<span>Payment Reference ID:</span>
<span id="display-payment-id"
class="font-mono text-xs text-slate-800 bg-white border border-slate-100 px-2 py-0.5 rounded">pay_loading...</span>
</div>
<div class="flex justify-between">
<span>Checkout Session:</span>
<span id="display-session-id" class="font-mono text-xs text-slate-600">cs_loading...</span>
</div>
<div class="flex justify-between">
<span>Payment Status:</span>
<span
class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">Captured</span>
</div>
</div>
<p class="text-xs text-slate-400">Our team will manually verify your UTR number and confirm your booking via WhatsApp or email within 30 minutes.</p>
<div class="flex flex-col sm:flex-row gap-3 pt-2">
<a href="/"
class="flex-1 bg-indigo-600 hover:bg-indigo-700 active:scale-[0.98] transition-transform text-white font-medium py-3.5 rounded-xl shadow-lg hover:shadow-indigo-100 text-center text-sm">
Return to Home
</a>
<a href="/"
class="flex-1 border border-slate-200 hover:bg-slate-50 active:scale-[0.98] transition-transform text-slate-600 font-medium py-3.5 rounded-xl text-center text-sm">
Browse Art
</a>
</div>
</div>
</main>
<app-footer></app-footer>
<script>
const urlParams = new URLSearchParams(window.location.search);
const paymentId = urlParams.get('payment') || 'pay_1A2B3C4D5E6F7G8H';
const sessionId = urlParams.get('session') || 'cs_1A2B3C4D5E6F7G8H';
document.getElementById('display-payment-id').innerText = paymentId;
document.getElementById('display-session-id').innerText = sessionId;
document.getElementById('product-name').innerText = urlParams.get('product') || 'Art Purchase';
document.getElementById('product-amount').innerText = '₹' + (urlParams.get('amount') || '1,308.50');
</script>
<script src="content-loader.js"></script>
</body>
</html>