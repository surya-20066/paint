.shiny-gradient-btn {
background: linear-gradient(135deg, #312E81 0%, #4F46E5 50%, #818CF8 100%);
position: relative;
overflow: hidden;
}
.shimmer::after {
content: "";
position: absolute;
top: -50%;
left: -50%;
width: 200%;
height: 200%;
background: linear-gradient(to bottom right,
rgba(255, 255, 255, 0) 0%,
rgba(255, 255, 255, 0) 40%,
rgba(255, 255, 255, 0.4) 50%,
rgba(255, 255, 255, 0) 60%,
rgba(255, 255, 255, 0) 100%);
transform: rotate(45deg);
animation: shimmer 3s infinite;
}
@keyframes shimmer {
0% {
transform: translateX(-100%) rotate(45deg);
}
100% {
transform: translateX(100%) rotate(45deg);
}
}
.gold-frame {
border: 4px solid #D97706;
box-shadow: 0 0 15px rgba(217, 119, 6, 0.2);
}
.upi-id-box {
background: #F1F5F9;
color: #1E293B;
font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}
.sticky-summary {
position: sticky;
top: 88px;
z-index: 30;
}

/* FOOTER CSS INJECTION */
footer {
background: #FDFBF7;
color: #1A1208;
padding: 100px 0 40px;
position: relative;
font-family: 'Outfit', sans-serif;
}
footer::before {
content: '';
position: absolute;
top: 0;
left: 0;
right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, #B5451B, transparent);
}
.foot-top {
display: grid;
grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
gap: 48px;
margin-bottom: 60px;
}
.foot-brand p {
color: rgba(26, 18, 8, 0.7);
font-size: 14px;
margin: 20px 0 24px;
max-width: 320px;
line-height: 1.6;
}
.socials {
display: flex;
gap: 12px;
}
.socials a {
width: 40px;
height: 40px;
border: 1px solid rgba(26, 18, 8, 0.15);
border-radius: 50%;
display: grid;
place-items: center;
color: #1A1208;
transition: all 0.3s ease;
}
.socials a:hover {
background: #B5451B;
color: white;
border-color: #B5451B;
transform: translateY(-3px);
}
.foot-col h5 {
font-family: 'Cormorant Garamond', serif;
font-style: italic;
font-size: 15px;
margin-bottom: 24px;
color: #B5451B;
font-weight: 700;
letter-spacing: 0.05em;
}
.foot-col ul {
list-style: none;
padding: 0;
}
.foot-col li {
margin-bottom: 12px;
}
.foot-col a {
font-size: 14px;
color: rgba(26, 18, 8, 0.75);
transition: color 0.3s ease;
text-decoration: none;
}
.foot-col a:hover {
color: #B5451B;
}
.foot-bot {
border-top: 1px solid rgba(26, 18, 8, 0.1);
padding-top: 32px;
display: flex;
justify-content: space-between;
align-items: center;
color: rgba(26, 18, 8, 0.5);
font-size: 13px;
flex-wrap: wrap;
gap: 16px;
}
@media (max-width: 1024px) {
.foot-top { grid-template-columns: repeat(3, 1fr); }
.foot-brand { grid-column: span 3; margin-bottom: 20px; }
}
@media (max-width: 768px) {
.foot-top { grid-template-columns: repeat(2, 1fr); }
.foot-brand { grid-column: span 2; }
}
</style>
