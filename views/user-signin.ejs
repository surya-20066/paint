<script>
function switchTab(tab) {
  const loginForm = document.getElementById('signin-form');
  const signupForm = document.getElementById('signup-form');
  const tabLoginBtn = document.getElementById('tab-login');
  const tabSignupBtn = document.getElementById('tab-signup');
  const activeClass = "px-6 py-2 rounded-full bg-white shadow-sm text-on-surface font-bold font-label-sm uppercase tracking-wider transition-all text-xs";
  const inactiveClass = "px-6 py-2 rounded-full text-on-surface-variant font-label-sm uppercase tracking-wider transition-all text-xs";
  const portalTitle = document.getElementById('portal-title');

  if (tab === 'login') {
    loginForm.classList.remove('hidden');
    signupForm.classList.add('hidden');
    tabLoginBtn.className = activeClass;
    tabSignupBtn.className = inactiveClass;
    if (portalTitle) portalTitle.textContent = 'User Sign In';
    const url = new URL(window.location);
    url.searchParams.delete('mode');
    window.history.replaceState({}, '', url);
  } else {
    loginForm.classList.add('hidden');
    signupForm.classList.remove('hidden');
    tabLoginBtn.className = inactiveClass;
    tabSignupBtn.className = activeClass;
    if (portalTitle) portalTitle.textContent = 'User Sign Up';
    const url = new URL(window.location);
    url.searchParams.set('mode', 'signup');
    window.history.replaceState({}, '', url);
  }
}

(function seedCollectorDemo() {
  let users = {};
  try {
    users = JSON.parse(localStorage.getItem('users') || '{}');
    if (typeof users !== 'object' || Array.isArray(users)) users = {};
  } catch(e) {
    users = {};
  }
  if (!users['user@paintedmuse.com']) {
    users['user@paintedmuse.com'] = {
      password: 'User@2025',
      fullName: 'Sathwik',
      spec: 'Collector',
      isApproved: true,
      isRejected: false
    };
    try { localStorage.setItem('users', JSON.stringify(users)); } catch(e) {}
  }
})();

// SIGN IN SUBMIT
document.getElementById('signin-form').addEventListener('submit', function (e) {
  e.preventDefault();
  const emailInput = document.getElementById('email');
  const passwordInput = document.getElementById('password');
  const email = emailInput.value.trim();
  const password = passwordInput.value;
  const errorEl = document.getElementById('signin-error');
  const submitBtn = this.querySelector('button[type="submit"]');
  const btnContent = submitBtn.innerHTML;

  errorEl.classList.add('hidden');
  document.querySelectorAll('.field-error').forEach(el => el.remove());

  let hasError = false;
  if (!email || !email.includes('@')) {
    showFieldError(emailInput, 'Please enter a valid email address.');
    hasError = true;
  }
  if (!password || password.length < 6) {
    showFieldError(passwordInput, 'Password must be at least 6 characters.');
    hasError = true;
  }
  if (hasError) return;

  submitBtn.disabled = true;
  submitBtn.innerHTML = `
    <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
    <span>Verifying Patron...</span>
  `;

  fetch('/auth/user-signin', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password })
  })
  .then(res => res.json())
  .then(data => {
      if (!data.success) {
          errorEl.textContent = data.message;
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.innerHTML = btnContent;
      } else {
          // Sync localStorage for Navbar state temporarily
          localStorage.setItem('userLoggedIn', 'true');
          const redirectUrl = localStorage.getItem('redirectAfterLogin') || data.redirect;
          localStorage.removeItem('redirectAfterLogin');
          window.location.href = redirectUrl;
      }
  })
  .catch(err => {
      errorEl.textContent = 'Server error. Please try again.';
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.innerHTML = btnContent;
  });
});

// SIGN UP SUBMIT
document.getElementById('signup-form').addEventListener('submit', function(e) {
  e.preventDefault();
  const fullNameInput = document.getElementById('full-name');
  const emailInput = document.getElementById('signup-email');
  const passwordInput = document.getElementById('signup-password');
  const fullName = fullNameInput.value.trim();
  const email = emailInput.value.trim();
  const password = passwordInput.value;
  const errorEl = document.getElementById('signup-error');
  const submitBtn = this.querySelector('button[type="submit"]');
  const btnContent = submitBtn.innerHTML;

  errorEl.classList.add('hidden');
  document.querySelectorAll('.field-error').forEach(el => el.remove());

  let hasError = false;
  if (!fullName) {
    showFieldError(fullNameInput, 'Full Name is required.');
    hasError = true;
  }
  if (!email || !email.includes('@')) {
    showFieldError(emailInput, 'Please enter a valid email address.');
    hasError = true;
  }
  if (!password || password.length < 6) {
    showFieldError(passwordInput, 'Password must be at least 6 characters.');
    hasError = true;
  }
  if (hasError) return;

  submitBtn.disabled = true;
  submitBtn.innerHTML = `
    <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
    <span>Creating Profile...</span>
  `;

  fetch('/auth/user-signup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ fullName, email, password })
  })
  .then(res => res.json())
  .then(data => {
      if (!data.success) {
          errorEl.textContent = data.message;
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.innerHTML = btnContent;
      } else {
          // Automatically log user in
          localStorage.setItem('userLoggedIn', 'true');
          const redirectUrl = localStorage.getItem('redirectAfterLogin') || data.redirect;
          localStorage.removeItem('redirectAfterLogin');
          window.location.href = redirectUrl;
      }
  })
  .catch(err => {
      errorEl.textContent = 'Server error. Please try again.';
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.innerHTML = btnContent;
  });
});

function showFieldError(inputEl, message) {
  const existing = inputEl.closest('.space-y-1')?.querySelector('.field-error');
  if (existing) existing.remove();
  const errDiv = document.createElement('div');
  errDiv.className = 'field-error text-red-600 text-[11px] font-medium mt-1';
  errDiv.textContent = message;
  inputEl.closest('.relative')?.after(errDiv);
  inputEl.classList.add('border-red-400');
  inputEl.addEventListener('input', function handler() {
    errDiv.remove();
    inputEl.classList.remove('border-red-400');
    inputEl.removeEventListener('input', handler);
  }, { once: true });
}

document.addEventListener('DOMContentLoaded', () => {
  const urlParams = new URLSearchParams(window.location.search);
  const mode = urlParams.get('mode');
  if (mode === 'signup') {
    switchTab('signup');
  } else {
    switchTab('login');
  }

  const error = urlParams.get('error');
  const errorEl = document.getElementById('signin-error');
  if (error === 'auth') {
    errorEl.textContent = 'Please log in to access your collector dashboard.';
    errorEl.classList.remove('hidden');
  }
});

function showSocialLoginNotice() {
  const errorEl = document.getElementById('signin-error') || document.getElementById('signup-error');
  errorEl.textContent = 'Social login is not available. Please use email and password.';
  errorEl.classList.remove('hidden');
  setTimeout(() => errorEl.classList.add('hidden'), 4000);
}
</script>
