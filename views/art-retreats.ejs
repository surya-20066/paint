<style>
:root {
--ink: #1A1208;
--saffron: #D4AF37;
--bg: #FDFBF7;
--cream: #F5F0E8;
--terracotta: #B5451B;
}
body {
background-color: var(--bg);
color: var(--ink);
font-family: 'Outfit', sans-serif;
scroll-behavior: smooth;
}
.serif {
font-family: 'Cormorant Garamond', serif;
}
.glass {
background: rgba(255, 255, 255, 0.7);
backdrop-filter: blur(15px);
border: 1px solid rgba(255, 255, 255, 0.3);
}
.retreat-section {
min-height: 100vh;
display: flex;
align-items: center;
padding: 100px 0;
position: relative;
overflow: hidden;
}
.retreat-image-frame {
height: 80vh;
width: 100%;
object-fit: cover;
border-radius: 2rem;
box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15);
}
.floating-label {
writing-mode: vertical-rl;
text-orientation: mixed;
transform: rotate(180deg);
}
.ink-grain {
background-image: url('data:image/svg+xml;base64,');
}
.section-tag {
font-size: 10px;
font-weight: 700;
letter-spacing: 0.4em;
text-transform: uppercase;
color: var(--saffron);
margin-bottom: 1.5rem;
display: block;
}
.reveal {
opacity: 0;
transform: translateY(40px);
transition: all 1s cubic-bezier(0.2, 0.8, 0.2, 1);
}
.reveal.active {
opacity: 1;
transform: translateY(0);
}


footer {
background: #FDFBF7;
color: var(--ink);
padding: 100px 0 40px;
position: relative;
}
footer::before {
content: '';
position: absolute;
top: 0;
left: 0;
right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, var(--terracotta), transparent);
}
.foot-top {
display: grid;
grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
gap: 48px;
margin-bottom: 60px;
}
.foot-brand p {
color: rgba(26, 18, 8, 0.7);
font-size: 14px;
margin: 20px 0 24px;
max-width: 320px;
line-height: 1.6;
}
.socials {
display: flex;
gap: 12px;
}
.socials a {
width: 40px;
height: 40px;
border: 1px solid rgba(26, 18, 8, 0.15);
border-radius: 50%;
display: grid;
place-items: center;
color: var(--ink);
transition: all 0.3s ease;
}
.socials a:hover {
background: var(--terracotta);
color: white;
border-color: var(--terracotta);
transform: translateY(-3px);
}
.foot-col h5 {
font-family: 'Cormorant Garamond', serif;
font-style: italic;
font-size: 15px;
margin-bottom: 24px;
color: var(--terracotta);
font-weight: 700;
letter-spacing: 0.05em;
}
.foot-col ul {
list-style: none;
padding: 0;
}
.foot-col li {
margin-bottom: 12px;
}
.foot-col a {
font-size: 14px;
color: rgba(26, 18, 8, 0.75);
transition: color 0.3s ease;
text-decoration: none;
}
.foot-col a:hover {
color: var(--terracotta);
}
.foot-bot {
border-top: 1px solid rgba(26, 18, 8, 0.1);
padding-top: 32px;
display: flex;
justify-content: space-between;
align-items: center;
color: rgba(26, 18, 8, 0.5);
font-size: 13px;
flex-wrap: wrap;
gap: 16px;
}
@media (max-width: 1024px) {
.foot-top { grid-template-columns: repeat(3, 1fr); }
.foot-brand { grid-column: span 3; margin-bottom: 20px; }
}
@media (max-width: 768px) {
.foot-top { grid-template-columns: repeat(2, 1fr); }
.foot-brand { grid-column: span 2; }
}
</style>
</head>
