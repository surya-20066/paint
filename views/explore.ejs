rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
rel="stylesheet" />
<style>
:root {
--ink: #1A1208;
--saffron: #D4AF37;
--bg: #FDFBF7;
--cream: #F5F0E8;
}
body {
background-color: var(--bg);
color: var(--ink);
font-family: 'DM Sans', sans-serif;
overflow-x: hidden;
}
.serif {
font-family: 'Playfair Display', serif;
}
.reveal {
opacity: 0;
transform: translateY(20px);
transition: all 0.8s ease-out;
}
.reveal.in {
opacity: 1;
transform: translateY(0);
}
.section-warm {
background-color: #FDFBF7;
}
.section-cream {
background-color: #F5F0E8;
}

footer {
background: #FDFBF7;
color: var(--ink);
padding: 100px 0 40px;
position: relative;
}
footer::before {
content: '';
position: absolute;
top: 0;
left: 0;
right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, var(--saffron), transparent);
}
.foot-top {
display: grid;
grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
gap: 48px;
margin-bottom: 60px;
}
.foot-brand p {
color: rgba(26, 18, 8, 0.7);
font-size: 14px;
margin: 20px 0 24px;
max-width: 320px;
line-height: 1.6;
}
.socials {
display: flex;
gap: 12px;
}
.socials a {
width: 40px;
height: 40px;
border: 1px solid rgba(26, 18, 8, 0.15);
border-radius: 50%;
display: grid;
place-items: center;
color: var(--ink);
transition: all 0.3s ease;
}
.socials a:hover {
background: var(--saffron);
color: var(--ink);
border-color: var(--saffron);
transform: translateY(-3px);
}
.foot-col h5 {
font-family: 'Playfair Display', serif;
font-style: italic;
font-size: 15px;
margin-bottom: 24px;
color: var(--saffron);
font-weight: 700;
letter-spacing: 0.05em;
}
.foot-col ul {
list-style: none;
padding: 0;
}
.foot-col li {
margin-bottom: 12px;
}
.foot-col a {
font-size: 14px;
color: rgba(26, 18, 8, 0.75);
transition: color 0.3s ease;
text-decoration: none;
}
.foot-col a:hover {
color: var(--ink);
}
.foot-bot {
border-top: 1px solid rgba(26, 18, 8, 0.1);
padding-top: 32px;
display: flex;
justify-content: space-between;
align-items: center;
color: rgba(26, 18, 8, 0.5);
font-size: 13px;
flex-wrap: wrap;
gap: 16px;
}
@media (max-width: 1024px) {
.foot-top { grid-template-columns: repeat(3, 1fr); }
.foot-brand { grid-column: span 3; margin-bottom: 20px; }
}
@media (max-width: 768px) {
.foot-top { grid-template-columns: repeat(2, 1fr); }
.foot-brand { grid-column: span 2; }
}
</style>
</head>
