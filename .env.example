# Application Configuration
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database Settings
# Leave DATABASE_URL empty or comment it out to use SQLite (default for local development)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/paymentgate

# Redis Settings (For background processing queues)
# Leave empty or comment out to use the built-in SQLite/In-memory queue fallback
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Payment Gateways (Stripe API Keys)
# Leave empty or set to "mock" to use the PaymentGate mock simulation mode
STRIPE_SECRET_KEY=mock
STRIPE_WEBHOOK_SECRET=mock

# Security Keys
JWT_SECRET=super_secret_jwt_key_paymentgate_32_chars_long
WEBHOOK_SECRET=super_secret_webhook_signature_key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
