<script>
function bookEvent(price, eventName) {
  const isLoggedIn = localStorage.getItem('userLoggedIn') === 'true';
  if (isLoggedIn) {
    window.location.href = `/payment?price=${price}&item=${encodeURIComponent(eventName)}`;
  } else {
    // Save intended destination
    localStorage.setItem('redirectAfterLogin', `/payment?price=${price}&item=${encodeURIComponent(eventName)}`);
    window.location.href = '/user-signin?error=auth';
  }
}

const observerOptions = {
threshold: 0.1
};
const observer = new IntersectionObserver((entries) => {
entries.forEach(entry => {
if (entry.isIntersecting) {
entry.target.classList.add('active');
}
});
}, observerOptions);
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
