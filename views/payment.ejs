<script>
// ===== UNIVERSAL PAYMENT GATEWAY SCRIPT =====
var UPI_ID = 'paintedmuse@upi';
var UPI_NAME = 'ThePaintedMuse';
var PLATFORM_FEE = 12.50;
var TAX_RATE = 0.08; // 8%

function formatINR(num) {
  return '₹' + num.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function buildQrUrl(amount) {
  var upiString = 'upi://pay?pa=' + UPI_ID + '&pn=' + UPI_NAME + '&am=' + amount.toFixed(2) + '&cu=INR&tn=ArtPurchase';
  return 'https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=' + encodeURIComponent(upiString) + '&bgcolor=ffffff&color=1A1208&qzone=2';
}

// Fallback QR
document.getElementById('upi-qr-img').onerror = function() {
  var currentTotal = parseFloat(this.dataset.amount) || 1308.50;
  this.src = 'https://chart.googleapis.com/chart?chs=300x300&cht=qr&chl=' +
    encodeURIComponent('upi://pay?pa=' + UPI_ID + '&pn=' + UPI_NAME + '&am=' + currentTotal.toFixed(2) + '&cu=INR') +
    '&choe=UTF-8';
};

// Admin QR override
document.addEventListener('DOMContentLoaded', function() {
  var adminQr = localStorage.getItem('admin_payment_qr');
  if (adminQr) {
    document.getElementById('upi-qr-img').src = adminQr;
  }
});

// ===== DYNAMIC PRICE UPDATE FROM URL PARAMS =====
(function() {
  var urlParams = new URLSearchParams(window.location.search);
  var item = urlParams.get('item');
  var price = urlParams.get('price');

  if (item && price) {
    var subtotal = parseFloat(price);
    if (isNaN(subtotal) || subtotal <= 0) return;

    var tax = subtotal * TAX_RATE;
    var total = subtotal + PLATFORM_FEE + tax;

    // Update item name & tier
    document.getElementById('pg-item-name').textContent = item;
    document.getElementById('pg-item-tier').textContent = 'One-time Purchase';

    // Update price breakdown
    document.getElementById('pg-subtotal').textContent = formatINR(subtotal);
    document.getElementById('pg-platform-fee').textContent = formatINR(PLATFORM_FEE);
    document.getElementById('pg-tax').textContent = formatINR(tax);
    document.getElementById('pg-total').textContent = formatINR(total);

    // Update QR subtitle
    document.getElementById('pg-qr-subtitle').textContent = 'Scan the QR or use manual ID to pay ' + formatINR(total);

    // Update QR code image with correct amount
    var qrImg = document.getElementById('upi-qr-img');
    qrImg.dataset.amount = total.toFixed(2);
    qrImg.src = buildQrUrl(total);

    // Update confirmation label
    document.getElementById('pg-confirm-label').innerHTML =
      'I confirm I have transferred exactly <strong class="text-secondary">' + formatINR(total) + '</strong> to <strong class="text-secondary">' + UPI_ID + '</strong>';
  }
})();

function copyUPI() {
  navigator.clipboard.writeText(UPI_ID).then(function() {
    var btnText = document.getElementById('copy-btn-text');
    var btn = document.getElementById('copy-upi-btn');
    btnText.innerText = "Copied ✓";
    btn.classList.add('bg-green-600', 'text-white', 'border-green-600');
    btn.classList.remove('bg-white', 'text-primary', 'border-primary/20');
    setTimeout(function() {
      btnText.innerText = "Copy";
      btn.classList.remove('bg-green-600', 'text-white', 'border-green-600');
      btn.classList.add('bg-white', 'text-primary', 'border-primary/20');
    }, 2000);
  });
}

function handleUpiSubmit(e) {
  e.preventDefault();
  var name = document.getElementById('user-name').value;
  var utr = document.getElementById('transaction-id').value;
  if (!name || !utr) return;

  var totalText = document.getElementById('pg-total').textContent;
  var itemName = document.getElementById('pg-item-name').textContent || 'Art Purchase';
  var amountNum = parseFloat(totalText.replace(/[^0-9.]/g, ''));
  var bookingRef = "TPM-" + Math.floor(100000 + Math.random() * 900000);
  
  var submitBtn = e.target.querySelector('button[type="submit"]');
  var originalText = submitBtn.innerHTML;
  submitBtn.innerHTML = 'Processing...';
  submitBtn.disabled = true;

  fetch('/api/payments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
          transactionId: utr,
          customerName: name,
          amount: amountNum,
          itemName: itemName,
          bookingReference: bookingRef
      })
  }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.success) {
          var paymentSection = document.getElementById('payment-form-section');
          paymentSection.innerHTML = '<div class="flex flex-col items-center justify-center py-xxl px-lg text-center">' +
            '<div class="w-24 h-24 rounded-full bg-green-50 flex items-center justify-center mb-lg border border-green-200">' +
            '<span class="material-symbols-outlined text-green-600 text-[64px]" style="font-variation-settings: \'FILL\' 1;">check_circle</span>' +
            '</div>' +
            '<h2 class="font-headline-md text-headline-md text-secondary mb-md">Payment Details Submitted</h2>' +
            '<p class="font-body-md text-on-surface-variant max-w-md mx-auto">' +
            'Thank you, <strong>' + name + '</strong>. Your transaction of <strong>' + totalText + '</strong> (ID: <strong>' + utr + '</strong>) has been successfully captured for verification.' +
            '</p>' +
            '<div class="mt-xl p-lg bg-surface-container rounded-2xl border border-primary/20 w-full max-w-sm">' +
            '<p class="font-label-sm text-on-surface-variant uppercase tracking-widest mb-xs font-bold">Booking Reference</p>' +
            '<p class="font-headline-sm text-headline-sm tracking-widest text-primary font-bold">' + bookingRef + '</p>' +
            '</div>' +
            '<div class="mt-xl flex flex-col gap-sm">' +
            '<p class="text-xs text-on-surface-variant">Estimated verification time: ~15-30 minutes</p>' +
            '<button onclick="window.location.href=\'/\'" class="text-primary font-bold hover:underline">Return to Home</button>' +
            '</div>' +
            '</div>';
          paymentSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
          alert(data.message || 'Error submitting payment.');
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
      }
  }).catch(function(err) {
      console.error(err);
      alert('Network error submitting payment.');
      submitBtn.innerHTML = originalText;
      submitBtn.disabled = false;
  });
}
</script>
<script src="content-loader.js"></script>
