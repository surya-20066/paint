<span class="material-symbols-outlined text-4xl">close</span>
</button>
<div class="max-w-4xl max-h-[85vh] w-full flex flex-col items-center justify-center space-y-4" onclick="event.stopPropagation()">
<img id="lightbox-img" class="max-w-full max-h-[75vh] object-contain rounded-lg shadow-2xl" src="" />
<h4 id="lightbox-title" class="text-white font-headline-md text-xl font-bold">Artwork</h4>
</div>
</div>
<script>
document.addEventListener('DOMContentLoaded', async () => {
let user = null;
try {
  user = JSON.parse(localStorage.getItem('currentUser'));
} catch(e) {
  console.error("Corrupted currentUser", e);
}
if (!user) {
window.location.href = '/';
return;
}
let usersDb = {};
try {
  usersDb = JSON.parse(localStorage.getItem('users') || '{}');
  if (typeof usersDb !== 'object' || Array.isArray(usersDb)) usersDb = {};
} catch(e) {
  usersDb = {};
}
const userInDb = usersDb[user.email];
if (!userInDb || !userInDb.isApproved) {
window.location.href = '/?error=pending';
return;
}

const loadProfile = () => {
const storedProfile = localStorage.getItem('artist_profile_' + user.email);
if (storedProfile) {
const profile = JSON.parse(storedProfile);
const welcomeHeader = document.querySelector('h1.font-headline-lg');
if (welcomeHeader) welcomeHeader.textContent = profile.fullName;
const sbImg = document.getElementById('sidebar-img');
const sbName = document.getElementById('sidebar-name');
const sbRole = document.getElementById('sidebar-role');
if (sbImg) sbImg.src = profile.photoUrl;
if (sbName) sbName.textContent = profile.displayName;
if (sbRole) sbRole.textContent = (profile.specialization || "Master Artist").toUpperCase();
}
};
loadProfile();

const dbName = "ReelsDB";
const storeName = "videos";
let db;
const initDB = () => {
return new Promise((resolve, reject) => {
const request = indexedDB.open(dbName, 1);
request.onupgradeneeded = (event) => {
const db = event.target.result;
if (!db.objectStoreNames.contains(storeName)) {
db.createObjectStore(storeName, { keyPath: "id", autoIncrement: true });
}
};
request.onsuccess = (event) => {
db = event.target.result;
resolve(db);
};
request.onerror = (event) => reject(event.target.error);
});
};
const saveVideo = (file) => {
if (!db) return;
let user = null;
try {
  user = JSON.parse(localStorage.getItem('currentUser'));
} catch(e) {}
if (!user) return;
const transaction = db.transaction([storeName], "readwrite");
const store = transaction.objectStore(storeName);
let artistName = user.fullName;
let handle = "@" + user.fullName.toLowerCase().replace(/\s+/g, '_');
try {
const profileKey = 'artist_profile_' + user.email;
const storedProfile = localStorage.getItem(profileKey);
if (storedProfile) {
const profile = JSON.parse(storedProfile);
if (profile.displayName) {
artistName = profile.displayName;
handle = "@" + profile.displayName.toLowerCase().replace(/\s+/g, '_');
}
}
} catch (e) { }
const record = {
file: file,
timestamp: Date.now(),
artistName: artistName,
handle: handle,
title: "Uploaded Reel",
userEmail: user.email
};
const request = store.add(record);
request.onsuccess = () => {
loadRecentUploads();
};
};
const createPostCard = (post) => {
const div = document.createElement('div');
div.className = "bg-surface-container-lowest border border-outline-variant group cursor-pointer hover:shadow-lg transition-shadow";
div.onclick = () => window.location.href = '/';
div.innerHTML = `
<div class="aspect-square bg-surface-variant overflow-hidden">
<img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="${post.imgUrl}" onerror="this.src='https://placehold.co/600x600/F5F0E8/B5451B?text=Artwork'"/>
</div>
<div class="p-4">
<h4 class="font-headline-md text-lg mb-1">${post.title}</h4>
<div class="flex justify-between"><span class="text-xs text-on-surface-variant">${post.category || 'Artwork'}</span><span class="text-sm text-primary font-bold">₹${Number(post.price).toLocaleString()}</span></div>
</div>
`;
return div;
};
const createReelCard = (reel) => {
const reelUrl = reel.file ? URL.createObjectURL(reel.file) : reel.videoUrl;
const div = document.createElement('div');
div.className = "bg-surface-container-lowest border border-outline-variant group cursor-pointer hover:shadow-lg transition-shadow relative overflow-hidden";
div.onclick = () => window.location.href = '/';
div.innerHTML = `
<div class="aspect-square bg-surface-variant overflow-hidden relative">
${reel.file ? `<video class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" src="${reelUrl}#t=0.1" muted></video>` : `<img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="${reel.videoUrl}" />`}
<div class="absolute inset-0 bg-black/20 flex items-center justify-center">
<span class="material-symbols-outlined text-white text-5xl opacity-80">play_circle</span>
</div>
</div>
<div class="p-4">
<h4 class="font-headline-md text-lg mb-1">${reel.title || 'Uploaded Reel'}</h4>
<div class="flex justify-between"><span class="text-xs text-on-surface-variant">Reel</span><span class="text-sm text-primary font-bold text-green-700">New</span></div>
</div>
`;
return div;
};
const loadRecentUploads = async () => {
const grid = document.getElementById('recent-uploads-grid');
if (!grid) return;
let posts = [];
try {
  posts = JSON.parse(localStorage.getItem('artist_posts_' + user.email) || '[]');
  if (!Array.isArray(posts)) posts = [];
} catch(e) {
  posts = [];
}
let reels = [];
if (db) {
const transaction = db.transaction([storeName], "readonly");
const store = transaction.objectStore(storeName);
const allReels = await new Promise((resolve) => {
const req = store.getAll();
req.onsuccess = () => resolve(req.result || []);
});
reels = allReels.filter(r => r.userEmail === user.email);
}
grid.innerHTML = '';
const uploadBtn = document.createElement('div');
uploadBtn.className = "bg-surface-container-lowest border border-outline-variant group cursor-pointer hover:shadow-lg transition-shadow upload-btn-card";
uploadBtn.onclick = () => document.getElementById('reelUploadInput').click();
uploadBtn.innerHTML = `
<div class="aspect-square bg-surface-variant overflow-hidden flex items-center justify-center"><span
class="material-symbols-outlined text-primary text-6xl">videocam</span></div>
<div class="p-4 text-center">
<h4 class="font-body-md text-on-surface-variant">Upload New Reel</h4>
</div>
<input type="file" id="reelUploadInput" accept="video/*" capture="environment" class="hidden">
`;
grid.appendChild(uploadBtn);
const fileInput = uploadBtn.querySelector('#reelUploadInput');
fileInput.addEventListener('change', (e) => {
const file = e.target.files[0];
if (file) {
saveVideo(file);
alert('Reel uploaded successfully!');
}
});

const approvalBanner = document.getElementById('approval-status-banner');
if (approvalBanner) {
let usersDb = {};
try {
  usersDb = JSON.parse(localStorage.getItem('users') || '{}');
  if (typeof usersDb !== 'object' || Array.isArray(usersDb)) usersDb = {};
} catch(e) {
  usersDb = {};
}
const userInDb = usersDb[user.email];
if (userInDb) {
const approvalIcon = document.getElementById('approval-banner-icon');
const approvalTitle = document.getElementById('approval-banner-title');
const approvalDesc = document.getElementById('approval-banner-desc');
if (userInDb.isApproved) {

approvalBanner.className = "mb-6 p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 flex items-center gap-3";
if (approvalIcon) approvalIcon.textContent = "check_circle";
if (approvalTitle) approvalTitle.textContent = "Profile Approved";
if (approvalDesc) approvalDesc.textContent = "Your profile is verified and active! Your artworks are visible to the public.";
approvalBanner.classList.remove('hidden');
} else if (userInDb.isRejected) {

approvalBanner.className = "mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 flex items-center gap-3";
if (approvalIcon) approvalIcon.textContent = "error";
if (approvalTitle) approvalTitle.textContent = "Profile Rejected";
if (approvalDesc) approvalDesc.textContent = "Your profile did not pass verification. Please contact support or update your settings.";
approvalBanner.classList.remove('hidden');
} else {

approvalBanner.className = "mb-6 p-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 flex items-center gap-3";
if (approvalIcon) approvalIcon.textContent = "pending";
if (approvalTitle) approvalTitle.textContent = "Pending Verification";
if (approvalDesc) approvalDesc.textContent = "Your artist registration is currently being reviewed. You can upload artwork, but your profile will only be visible publicly after approval.";
approvalBanner.classList.remove('hidden');
}
}
}
const combined = [
...posts.map(p => ({ ...p, type: 'post' })),
...reels.map(r => ({ ...r, type: 'reel' }))
].sort((a, b) => (b.timestamp || 0) - (a.timestamp || 0));
combined.slice(0, 5).forEach(item => {
if (item.type === 'post') {
grid.appendChild(createPostCard(item));
} else {
grid.appendChild(createReelCard(item));
}
});

const sidebarName = document.getElementById('sidebar-name');
const sidebarRole = document.getElementById('sidebar-role');
const sbImg = document.getElementById('sidebar-img');
const headers = document.querySelectorAll('header h1.text-4xl');
if (sidebarName) sidebarName.textContent = user.fullName.toUpperCase();
if (sidebarRole && user.spec) {
sidebarRole.textContent = user.spec.toUpperCase() + ' ARTIST';
}
headers.forEach(h => {
if (h.textContent.includes('Amrita') || h.textContent.includes('Raghavan')) {
h.textContent = user.fullName;
}
});

const profileKey = 'artist_profile_' + user.email;
const storedProfile = localStorage.getItem(profileKey);
if (storedProfile) {
let profile = null;
try {
  profile = JSON.parse(storedProfile);
} catch(e) {}
if (profile) {
if (sidebarName && profile.displayName) sidebarName.textContent = profile.displayName.toUpperCase();
if (sidebarRole && profile.specialization) {
sidebarRole.textContent = profile.specialization.toUpperCase() + ' ARTIST';
}
if (sbImg && profile.photoUrl) sbImg.src = profile.photoUrl;
const mainImg = document.querySelector('aside img') || document.querySelector('.bg-surface-dim img');
if (mainImg && profile.photoUrl) mainImg.src = profile.photoUrl;
headers.forEach(h => {
h.textContent = profile.displayName;
});
}
} else if (user.isNewUser) {
if (sbImg) sbImg.src = 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=100';
const mainImg = document.querySelector('aside img') || document.querySelector('.bg-surface-dim img');
if (mainImg) mainImg.src = 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=100';
}
if (user.isNewUser) {

const statArtworks = document.getElementById('stat-artworks');
const statArtworksSub = document.getElementById('stat-artworks-sub');
const statViews = document.getElementById('stat-views');
const statViewsSub = document.getElementById('stat-views-sub');
const statSold = document.getElementById('stat-sold');
const statSoldSub = document.getElementById('stat-sold-sub');
const statEarnings = document.getElementById('stat-earnings');
const statEarningsSub = document.getElementById('stat-earnings-sub');
if (statArtworks) statArtworks.textContent = reels.length + posts.length;
if (statArtworksSub) statArtworksSub.textContent = 'Uploaded by you';
if (statViews) statViews.textContent = '0';
if (statViewsSub) statViewsSub.textContent = 'No views yet';
if (statSold) statSold.textContent = '0';
if (statSoldSub) statSoldSub.textContent = 'No sales yet';
if (statEarnings) statEarnings.textContent = '₹0';
if (statEarningsSub) statEarningsSub.textContent = '₹0 this month';
}
};
initDB().then(() => {
  loadRecentUploads();
  loadPortfolioShowcase();
}).catch(err => {
  console.error("DB Init failed", err);
  loadRecentUploads();
  loadPortfolioShowcase();
});

// Scroll to portfolio section if hash is #portfolio
if (window.location.hash === '#portfolio') {
  setTimeout(() => {
    const portfolioEl = document.getElementById('portfolio');
    if (portfolioEl) portfolioEl.scrollIntoView({ behavior: 'smooth' });
  }, 400);
}
});

/* ═══════════════════════════════════════════════ */
/*          PORTFOLIO SHOWCASE FUNCTIONS           */
/* ═══════════════════════════════════════════════ */

let selectedPatternUrl = 'pics/warli_pattern_1778230295803.png';
let selectedBgColor = '#FDFBF7';
let artistPosts = [];

function togglePortfolioDrawer(show) {
  const drawer = document.getElementById('edit-drawer');
  const overlay = document.getElementById('edit-drawer-overlay');
  let user = null;
  try { user = JSON.parse(localStorage.getItem('currentUser')); } catch(e) {}
  if (!user) return;
  if (show) {
    const profileKey = 'artist_profile_' + user.email;
    const profile = JSON.parse(localStorage.getItem(profileKey) || '{}');
    document.getElementById('inp-calligraphy').value = profile.calligraphy || 'Artistic Excellence';
    document.getElementById('inp-achievements').value = profile.achievements ||
      "• Solo Exhibition, Visual Arts Gallery, New Delhi (2023)\n• State Award for Traditional Crafts, Government of Bihar (2021)\n• National Traditional Conclave Participant (2020)";
    selectedBgColor = profile.themeBgColor || '#FDFBF7';
    selectedPatternUrl = profile.themePattern || 'pics/warli_pattern_1778230295803.png';
    drawer.classList.remove('translate-x-full');
    overlay.classList.remove('hidden');
  } else {
    drawer.classList.add('translate-x-full');
    overlay.classList.add('hidden');
  }
}

function selectPattern(url, btn) {
  selectedPatternUrl = url;
  const buttons = btn.parentElement.querySelectorAll('button');
  buttons.forEach(b => {
    b.classList.remove('border-primary');
    b.classList.add('border-outline-variant');
  });
  btn.classList.remove('border-outline-variant');
  btn.classList.add('border-primary');
}

document.querySelectorAll('.color-swatch').forEach(swatch => {
  swatch.addEventListener('click', () => {
    selectedBgColor = swatch.getAttribute('data-color');
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
    swatch.classList.add('active');
  });
});

const customColorInput = document.getElementById('custom-color');
if (customColorInput) {
  customColorInput.addEventListener('input', (e) => {
    selectedBgColor = e.target.value;
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
  });
}

function savePortfolioSettings() {
  let user = null;
  try { user = JSON.parse(localStorage.getItem('currentUser')); } catch(e) {}
  if (!user) return;
  const profileKey = 'artist_profile_' + user.email;
  const profile = JSON.parse(localStorage.getItem(profileKey) || '{}');
  profile.calligraphy = document.getElementById('inp-calligraphy').value.trim();
  profile.achievements = document.getElementById('inp-achievements').value.trim();
  profile.themeBgColor = selectedBgColor;
  profile.themePattern = selectedPatternUrl;
  localStorage.setItem(profileKey, JSON.stringify(profile));
  togglePortfolioDrawer(false);
  loadPortfolioShowcase();
}

async function loadPortfolioShowcase() {
  let user = null;
  try { user = JSON.parse(localStorage.getItem('currentUser')); } catch(e) {}
  if (!user) return;
  const profileKey = 'artist_profile_' + user.email;
  const profile = JSON.parse(localStorage.getItem(profileKey) || '{}');

  const displayName = profile.displayName || user.fullName;
  const spec = profile.specialization || user.spec || 'Traditional Artist';
  const location = profile.cityState || 'India';
  const photoUrl = profile.photoUrl || 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=150';
  const bio = profile.bio || 'Crafting heritage art forms with meticulous devotion.';
  const calligraphy = profile.calligraphy || 'Artistic Excellence';
  const achievements = profile.achievements ||
    "• Solo Exhibition, Visual Arts Gallery, New Delhi (2023)\n• State Award for Traditional Crafts, Government of Bihar (2021)\n• National Traditional Conclave Participant (2020)";

  const bgColor = profile.themeBgColor || '#FDFBF7';
  const pattern = profile.themePattern || 'pics/warli_pattern_1778230295803.png';

  const container = document.getElementById('portfolio-showcase-container');
  if (container) container.style.backgroundColor = bgColor;
  const coverPattern = document.getElementById('showcase-cover-pattern');
  if (coverPattern) coverPattern.style.backgroundImage = `url('${pattern}')`;

  const bioPattern = document.querySelector('.bio-pattern');
  const achPattern = document.querySelector('.ach-pattern');
  if (bioPattern) bioPattern.style.backgroundImage = `url('${pattern}')`;
  if (achPattern) achPattern.style.backgroundImage = `url('${pattern}')`;

  const setTextById = (id, text) => { const el = document.getElementById(id); if (el) el.textContent = text; };
  const setSrcById = (id, src) => { const el = document.getElementById(id); if (el) el.src = src; };

  setSrcById('showcase-avatar', photoUrl);
  setTextById('showcase-name', displayName);
  setTextById('showcase-calligraphy', calligraphy);
  setTextById('showcase-spec', spec);
  setTextById('showcase-location', location);
  setTextById('showcase-bio', `"${bio}"`);

  // Links
  const linksContainer = document.getElementById('showcase-links');
  if (linksContainer) {
    linksContainer.innerHTML = '';
    const links = [
      { title: 'Website', url: profile.website, icon: 'language' },
      { title: 'Instagram', url: profile.instagram, icon: 'link' },
      { title: 'Behance', url: profile.behance, icon: 'share' }
    ];
    links.forEach(l => {
      if (l.url) {
        const btn = document.createElement('a');
        btn.href = l.url.startsWith('http') ? l.url : 'https://' + l.url;
        btn.target = '_blank';
        btn.className = "flex items-center gap-1.5 text-xs text-primary font-bold tracking-wide uppercase hover:underline bg-white/50 border border-outline-variant px-3 py-1.5 rounded-full backdrop-blur-sm shadow-sm transition-colors";
        btn.innerHTML = `<span class="material-symbols-outlined text-sm font-bold">${l.icon}</span> ${l.title}`;
        linksContainer.appendChild(btn);
      }
    });
  }

  // Achievements
  const achContainer = document.getElementById('showcase-achievements');
  if (achContainer) {
    achContainer.innerHTML = achievements.split('\n')
      .filter(l => l.trim() !== '')
      .map(l => `<li class="flex items-start gap-2.5"><span class="text-primary mt-1">•</span><span>${l.replace(/^[•\-\*\s]+/, '')}</span></li>`)
      .join('');
  }

  // Featured image
  const postsKey = 'artist_posts_' + user.email;
  artistPosts = JSON.parse(localStorage.getItem(postsKey) || '[]');
  const imgCard = document.getElementById('featured-image-card');
  if (imgCard) {
    if (artistPosts.length > 0) {
      const latestImg = artistPosts[artistPosts.length - 1];
      setSrcById('featured-image-img', latestImg.imgUrl);
      setTextById('featured-image-title', latestImg.title);
      setTextById('featured-image-category', latestImg.category || 'Artwork');
      const priceEl = document.getElementById('featured-image-price');
      if (priceEl) priceEl.textContent = '₹' + Number(latestImg.price).toLocaleString();
      imgCard.style.display = 'block';
    } else {
      imgCard.innerHTML = `
        <div class="aspect-video bg-surface-container-low overflow-hidden relative flex flex-col items-center justify-center p-8 text-center cursor-pointer" onclick="window.location.href='/'">
          <span class="material-symbols-outlined text-primary text-5xl mb-3">add_photo_alternate</span>
          <h4 class="font-headline-md text-lg font-bold text-on-surface">No Featured Image</h4>
          <p class="text-xs text-on-surface-variant/60 mt-1">Upload artwork in your Gallery to feature it here.</p>
        </div>
      `;
    }
  }

  // Featured video
  let videoUrl = 'pics/video.mp4';
  let videoTitle = 'Process Reel';
  let hasVideo = false;
  if (typeof db !== 'undefined' && db) {
    const transaction = db.transaction([storeName], "readonly");
    const store = transaction.objectStore(storeName);
    const request = store.getAll();
    await new Promise((resolve) => {
      request.onsuccess = () => {
        const allReels = request.result || [];
        const userReels = allReels.filter(r => r.userEmail === user.email);
        if (userReels.length > 0) {
          const latestReel = userReels[userReels.length - 1];
          videoUrl = latestReel.file ? URL.createObjectURL(latestReel.file) : latestReel.videoUrl;
          videoTitle = latestReel.title || 'Process Reel';
          hasVideo = true;
        }
        resolve();
      };
    });
  }
  const videoCard = document.getElementById('featured-video-card');
  const player = document.getElementById('featured-video-player');
  if (videoCard && player) {
    if (hasVideo) {
      player.src = videoUrl;
      setTextById('featured-video-title', videoTitle);
      videoCard.style.display = 'flex';
    } else {
      player.src = 'pics/video.mp4';
      setTextById('featured-video-title', 'Mithila Clay Painting Demo');
    }
  }
}

function openLightbox() {
  if (artistPosts.length === 0) return;
  const latestImg = artistPosts[artistPosts.length - 1];
  const modal = document.getElementById('lightbox-modal');
  document.getElementById('lightbox-img').src = latestImg.imgUrl;
  document.getElementById('lightbox-title').textContent = latestImg.title;
  modal.classList.remove('hidden');
  modal.classList.add('flex');
}
function closeLightbox() {
  const modal = document.getElementById('lightbox-modal');
  modal.classList.add('hidden');
  modal.classList.remove('flex');
}

function toggleShareDropdown() {
  document.getElementById('share-dropdown').classList.toggle('hidden');
}
window.addEventListener('click', (e) => {
  const container = document.getElementById('share-dropdown-container');
  if (container && !container.contains(e.target)) {
    document.getElementById('share-dropdown').classList.add('hidden');
  }
});

function shareAction(platform) {
  let user = null;
  try { user = JSON.parse(localStorage.getItem('currentUser')); } catch(e) {}
  if (!user) return;
  const shareUrl = window.location.origin + '//?artist=' + encodeURIComponent(user.email) + '#portfolio';
  const title = 'Exquisite Heritage Art Portfolio by ' + user.fullName;
  const message = 'Explore my portfolio and masterpieces at The Painted Muse: ' + shareUrl;
  document.getElementById('share-dropdown').classList.add('hidden');
  switch (platform) {
    case 'copy':
      navigator.clipboard.writeText(shareUrl).then(() => alert('Portfolio link copied!'));
      break;
    case 'whatsapp':
      window.open('https://api.whatsapp.com/send?text=' + encodeURIComponent(message), '_blank');
      break;
    case 'twitter':
      window.open('https://twitter.com/intent/tweet?url=' + encodeURIComponent(shareUrl) + '&text=' + encodeURIComponent(title), '_blank');
      break;
    case 'facebook':
      window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(shareUrl), '_blank');
      break;
  }
}
</script>
