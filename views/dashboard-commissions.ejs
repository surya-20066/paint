<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<title>Dashboard | The Painted Muse</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link
href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,700&amp;family=Outfit:wght@400;500;700&amp;family=Great+Vibes&amp;display=swap"
rel="stylesheet" />
<link
href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
rel="stylesheet" />
<script src="components/Navbar.js" defer></script>
<script src="components/Sidebar.js" defer></script>
<script src="components/Footer.js" defer></script>
<script>
(function checkUserAuth() {
  if (localStorage.getItem('userLoggedIn') !== 'true') {
    window.location.href = '/?error=auth';
  }
})();
</script>
<style>
:root {
--primary: #B5451B;
--accent: #D4AF37;
--background: #FDFBF7;
--text: #1A1208;
--cream: #F5F0E8;
--warm: #FFF8F0;
}
.material-symbols-outlined {
font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24
}
body {
background-color: var(--background);
color: var(--text);
font-family: 'Outfit', sans-serif;
}
/* Smooth Page Transition */
@keyframes pageFadeIn {
from { opacity: 0; transform: translateY(12px); }
to   { opacity: 1; transform: translateY(0); }
}
main .p-8,
main .max-w-5xl {
animation: pageFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.font-serif {
font-family: 'Cormorant Garamond', serif;
}
.font-calligraphy {
font-family: 'Great Vibes', cursive;
}
.ink-grain {
background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuCRrEuwmrE10cxB2Oae845GDrP3kU-WyjvkShm1EQbrQg1J8AWwsnfTOa_Yd43-yDsPK-k7jiLPfPtwwOdYsTOwnMBabRznvfeo8h3bqtwD5gH2q4U30MBCCjJNiRgFbchZDN5lhWytQEYI5xTmEfIbnzuDLCKKDPl8_NyfmuWMuR86PhGc-JnOKloK4F3ni1MSTH5prPAgGGKWuf8SBOUfiXyBj35iXGC3XCEi91OQTXGj39Posri3UHGrcYXiOqWISXFGxeYn7Z7y);
opacity: 0.03;
pointer-events: none;
position: fixed;
inset: 0;
z-index: 99;
}
.warli-border {
border: 1px solid rgba(212, 175, 55, 0.2);
position: relative;
}
.warli-border::before {
content: "";
position: absolute;
inset: 4px;
border: 1px solid rgba(212, 175, 55, 0.1);
pointer-events: none;
}
.glass-panel {
background: rgba(255, 255, 255, 0.7);
backdrop-filter: blur(10px);
border: 1px solid rgba(212, 175, 55, 0.1);
}
.sidebar-item.active {
color: var(--primary);
background: rgba(181, 69, 27, 0.05);
border-right: 3px solid var(--primary);
}
.artist-card:hover .artist-overlay {
opacity: 1;
}
@keyframes float {
0% {
transform: translateY(0px);
}
50% {
transform: translateY(-10px);
}
100% {
transform: translateY(0px);
}
}
.animate-float {
animation: float 4s ease-in-out infinite;
}
.custom-scrollbar::-webkit-scrollbar {
width: 6px;
}
.custom-scrollbar::-webkit-scrollbar-track {
background: rgba(26, 18, 8, 0.05);
}
.custom-scrollbar::-webkit-scrollbar-thumb {
background: var(--accent);
border-radius: 10px;
}

.no-scrollbar::-webkit-scrollbar {
display: none;
}
.no-scrollbar {
-ms-overflow-style: none;
scrollbar-width: none;
}
.shimmer {
background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.1), transparent);
background-size: 200% 100%;
animation: shimmer 2s infinite;
}
@keyframes shimmer {
0% {
background-position: -200% 0;
}
100% {
background-position: 200% 0;
}
}

footer {
background: #FDFBF7;
color: var(--text);
padding: 100px 0 40px;
position: relative;
}
footer::before {
content: '';
position: absolute;
top: 0;
left: 0;
right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, var(--primary), transparent);
}
.foot-top {
display: grid;
grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
gap: 48px;
margin-bottom: 60px;
}
.foot-brand p {
color: rgba(26, 18, 8, 0.7);
font-size: 14px;
margin: 20px 0 24px;
max-width: 320px;
line-height: 1.6;
}
.socials {
display: flex;
gap: 12px;
}
.socials a {
width: 40px;
height: 40px;
border: 1px solid rgba(26, 18, 8, 0.15);
border-radius: 50%;
display: grid;
place-items: center;
color: var(--text);
transition: all 0.3s ease;
}
.socials a:hover {
background: var(--primary);
color: white;
border-color: var(--primary);
transform: translateY(-3px);
}
.foot-col h5 {
font-family: 'Cormorant Garamond', serif;
font-style: italic;
font-size: 15px;
margin-bottom: 24px;
color: var(--primary);
font-weight: 700;
letter-spacing: 0.05em;
}
.foot-col ul {
list-style: none;
padding: 0;
}
.foot-col li {
margin-bottom: 12px;
}
.foot-col a {
font-size: 14px;
color: rgba(26, 18, 8, 0.75);
transition: color 0.3s ease;
text-decoration: none;
}
.foot-col a:hover {
color: var(--primary);
}
.foot-bot {
border-top: 1px solid rgba(26, 18, 8, 0.1);
padding-top: 32px;
display: flex;
justify-content: space-between;
align-items: center;
color: rgba(26, 18, 8, 0.5);
font-size: 13px;
flex-wrap: wrap;
gap: 16px;
}
@media (max-width: 1024px) {
.foot-top {
grid-template-columns: repeat(3, 1fr);
}
.foot-brand {
grid-column: span 3;
margin-bottom: 20px;
}
}
@media (max-width: 768px) {
.foot-top {
grid-template-columns: repeat(2, 1fr);
}
.foot-brand {
grid-column: span 2;
}
}
</style>
</head>
<body class="h-screen flex flex-col overflow-hidden pt-[90px] md:pt-[100px]">
<app-navbar></app-navbar>

<div id="dashboard-layout-wrapper" class="flex flex-1 overflow-hidden">
<div class="ink-grain"></div>
<dashboard-sidebar type="user"></dashboard-sidebar>
<main class="flex-1 flex flex-col h-full overflow-y-auto custom-scrollbar relative">
<header
class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-stone-100 px-8 py-4 flex justify-between items-center">
<div class="flex items-center gap-4 flex-1">
<button
class="mobile-menu-btn-toggle lg:hidden text-stone-900 p-2 flex items-center justify-center mr-2">
<span class="material-symbols-outlined text-2xl">menu</span>
</button>
<div class="relative max-w-md w-full">
<span
class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-stone-400 text-sm">search</span>
<input type="text" placeholder="Search artists, art retreats, or regions..."
class="w-full pl-10 pr-4 py-2 bg-stone-100 border-none rounded-lg text-sm focus:ring-1 focus:ring-[#D4AF37]">
</div>
</div>
<div class="flex items-center gap-6">
<button class="relative text-stone-500 hover:text-[#B5451B] transition-colors">
<span class="material-symbols-outlined">notifications</span>
<span class="absolute -top-1 -right-1 w-2 h-2 bg-[#B5451B] rounded-full"></span>
</button>
<button onclick="window.location.href='/'"
class="font-sans text-[10px] font-bold uppercase tracking-widest bg-[#B5451B] text-white px-4 py-2 rounded shadow-lg hover:bg-[#D4AF37] transition-all">Book
Artist</button>
</div>
</header>
<div class="p-8 space-y-12">
<section class="mb-12">
<h1 class="text-4xl font-serif text-[#1A1208] mb-2">My <span
class="italic text-[#D4AF37]">Commissions</span></h1>
<p class="text-stone-500 text-lg">Track the progress of your customized heritage artworks and past
collections.</p>
</section>
<section class="mb-16">
<h2 class="text-2xl font-serif text-[#1A1208] mb-6 border-b border-stone-200 pb-2">Active
Commissions</h2>
<div class="grid gap-6">
<div
class="glass-panel p-8 rounded-2xl border border-stone-200 flex flex-col md:flex-row gap-8 items-center bg-white shadow-sm hover:shadow-md transition-shadow">
<div class="w-40 h-40 rounded-xl overflow-hidden shadow-lg shrink-0 relative">
<img src="pics/kalamkari_art.png" class="w-full h-full object-cover" />
<div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
</div>
<div class="flex-1 w-full">
<div class="flex justify-between items-start mb-4 flex-wrap gap-4">
<div>
<h3 class="text-2xl font-serif font-bold text-[#1A1208]">Tree of Life Kalamkari
</h3>
<p class="text-sm text-[#B5451B] font-bold uppercase mt-1">Artist: Raghavendra
</p>
</div>
<span
class="px-4 py-2 bg-yellow-100 text-yellow-700 text-[10px] font-bold uppercase tracking-widest rounded shadow-sm border border-yellow-200">In
Progress</span>
</div>
<p class="text-sm text-stone-500 mb-4 line-clamp-2">"Working on the intricate border
detailing with natural dyes. The pomegranate reds are setting beautifully on the
cotton fabric." - Raghavendra</p>
<div
class="w-full bg-stone-100 rounded-full h-3 mb-3 shadow-inner overflow-hidden border border-stone-200">
<div class="bg-gradient-to-r from-[#D4AF37] to-[#B5451B] h-3 rounded-full"
style="width: 65%"></div>
</div>
<div class="flex justify-between text-xs text-stone-600 font-bold uppercase">
<p class="flex items-center gap-1"><span
class="material-symbols-outlined text-[14px]">calendar_today</span> Started:
Apr 12</p>
<p class="flex items-center gap-1"><span
class="material-symbols-outlined text-[14px]">local_shipping</span> Est.
Delivery: May 20</p>
</div>
<div class="mt-6 flex gap-4">
<button
class="px-6 py-2 border border-[#B5451B] text-[#B5451B] text-[10px] font-bold uppercase tracking-widest rounded hover:bg-[#B5451B] hover:text-white transition-colors">Message
Artist</button>
<button
class="px-6 py-2 border border-stone-300 text-stone-600 text-[10px] font-bold uppercase tracking-widest rounded hover:bg-stone-100 transition-colors">View
Details</button>
</div>
</div>
</div>
<div
class="glass-panel p-8 rounded-2xl border border-stone-200 flex flex-col md:flex-row gap-8 items-center bg-white shadow-sm hover:shadow-md transition-shadow">
<div class="w-40 h-40 rounded-xl overflow-hidden shadow-lg shrink-0 relative">
<img src="pics/madhubani_bg.png" class="w-full h-full object-cover" />
<div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
</div>
<div class="flex-1 w-full">
<div class="flex justify-between items-start mb-4 flex-wrap gap-4">
<div>
<h3 class="text-2xl font-serif font-bold text-[#1A1208]">Custom Wedding Kohbar
</h3>
<p class="text-sm text-[#B5451B] font-bold uppercase mt-1">Artist: Meera Devi
</p>
</div>
<span
class="px-4 py-2 bg-blue-100 text-blue-700 text-[10px] font-bold uppercase tracking-widest rounded shadow-sm border border-blue-200">Preparing
Materials</span>
</div>
<p class="text-sm text-stone-500 mb-4 line-clamp-2">"Sourcing handmade paper and
preparing organic pigments extracted from local flowers for your special wedding
piece." - Meera Devi</p>
<div
class="w-full bg-stone-100 rounded-full h-3 mb-3 shadow-inner overflow-hidden border border-stone-200">
<div class="bg-gradient-to-r from-blue-400 to-blue-600 h-3 rounded-full"
style="width: 20%"></div>
</div>
<div class="flex justify-between text-xs text-stone-600 font-bold uppercase">
<p class="flex items-center gap-1"><span
class="material-symbols-outlined text-[14px]">calendar_today</span> Started:
May 02</p>
<p class="flex items-center gap-1"><span
class="material-symbols-outlined text-[14px]">local_shipping</span> Est.
Delivery: June 15</p>
</div>
<div class="mt-6 flex gap-4">
<button
class="px-6 py-2 border border-[#B5451B] text-[#B5451B] text-[10px] font-bold uppercase tracking-widest rounded hover:bg-[#B5451B] hover:text-white transition-colors">Message
Artist</button>
<button
class="px-6 py-2 border border-stone-300 text-stone-600 text-[10px] font-bold uppercase tracking-widest rounded hover:bg-stone-100 transition-colors">View
Details</button>
</div>
</div>
</div>
</div>
</section>
<section class="mb-12">
<h2 class="text-2xl font-serif text-[#1A1208] mb-6 border-b border-stone-200 pb-2">Past Commissions
</h2>
<div class="grid gap-6">
<div
class="glass-panel p-6 rounded-2xl border border-stone-200 flex flex-col md:flex-row gap-6 items-center bg-stone-50 opacity-80 hover:opacity-100 transition-opacity">
<div class="w-24 h-24 rounded-lg overflow-hidden shadow shrink-0"><img
src="pics/tanjore_art.png" class="w-full h-full object-cover grayscale" /></div>
<div class="flex-1 w-full">
<div class="flex justify-between items-start mb-2">
<div>
<h3 class="text-lg font-serif font-bold text-[#1A1208]">Krishna Tanjore Panel
</h3>
<p class="text-xs text-stone-500 font-bold uppercase mt-1">Artist: Anjali Pichai
</p>
</div>
<span
class="px-3 py-1 bg-green-100 text-green-700 text-[9px] font-bold uppercase tracking-widest rounded border border-green-200">Delivered</span>
</div>
<div
class="flex justify-between text-[10px] text-stone-500 font-bold uppercase pt-3 border-t border-stone-200 mt-3">
<p>Delivered: Jan 05, 2026</p>
<p class="flex items-center gap-1 text-[#D4AF37]"><span
class="material-symbols-outlined text-[14px]">star</span> You Rated 5.0</p>
</div>
</div>
<div class="shrink-0 flex flex-col gap-2">
<button
class="w-full px-4 py-2 bg-stone-200 text-stone-700 text-[9px] font-bold uppercase tracking-widest rounded hover:bg-stone-300 transition-colors">Buy
Again</button>
<button
class="w-full px-4 py-2 border border-stone-300 text-stone-600 text-[9px] font-bold uppercase tracking-widest rounded hover:bg-stone-100 transition-colors">Invoice</button>
</div>
</div>
</div>
</section>
</div>
<app-footer></app-footer>
</main>
</div>
<script>
  // Auth check is handled in the head section.
</script>
<script src="content-loader.js"></script>
</body>
</html>