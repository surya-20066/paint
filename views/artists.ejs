<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<meta name="description"
content="Meet the legendary master artisans of India. Explore their stories, view portfolios, and book retreats directly with the keepers of ancient traditions." />
<title>Meet the Masters | The Painted Muse</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script src="components/Navbar.js" defer></script>
<script src="components/Footer.js" defer></script>
<link
href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,700&family=Outfit:wght@400;500;700&display=swap"
rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
rel="stylesheet" />
<style>
:root {
--ink: #1A1208;
--saffron: #D4AF37;
--bg: #FDFBF7;
--cream: #F5F0E8;
--terracotta: #B5451B;
}
body {
background-color: var(--bg);
color: var(--ink);
font-family: 'Outfit', sans-serif;
overflow-x: hidden;
}
.serif {
font-family: 'Cormorant Garamond', serif;
}
.reveal {
opacity: 0;
transform: translateY(20px);
transition: all 0.8s ease-out;
}
.reveal.in {
opacity: 1;
transform: translateY(0);
}

.artisan-card {
background: white;
border: 1px solid rgba(26, 18, 8, 0.08);
border-radius: 4px;
overflow: hidden;
transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
box-shadow: 0 4px 30px rgba(26, 18, 8, 0.02);
opacity: 0.3;
transform: scale(0.85);
filter: blur(3px);
}
.artisan-card.active {
opacity: 1;
transform: scale(1.1);
filter: blur(0);
box-shadow: 0 30px 70px rgba(26, 18, 8, 0.25);
border-color: var(--saffron);
z-index: 30;
border-width: 2px;
}
.search-bar {
border: 1px solid rgba(26, 18, 8, 0.1);
background: white;
border-radius: 100px;
padding: 12px 24px;
width: 100%;
max-width: 500px;
transition: all 0.3s ease;
}
.search-bar:focus-within {
border-color: var(--saffron);
box-shadow: 0 0 20px rgba(212, 175, 55, 0.1);
}

.filter-btn {
font-family: 'Outfit', sans-serif;
font-size: 10px;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 0.15em;
padding: 10px 24px;
border-radius: 100px;
border: 1px solid rgba(26, 18, 8, 0.1);
background: transparent;
color: var(--ink);
cursor: pointer;
transition: all 0.3s ease;
}
.filter-btn:hover {
border-color: var(--saffron);
background: rgba(212, 175, 55, 0.05);
}
.filter-btn.active {
background: var(--ink);
color: white;
border-color: var(--ink);
}

.custom-scrollbar::-webkit-scrollbar {
height: 4px;
width: 4px;
}
.custom-scrollbar::-webkit-scrollbar-track {
background: transparent;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
background: var(--saffron);
border-radius: 2px;
}
.custom-scrollbar-hide::-webkit-scrollbar {
display: none;
}
.custom-scrollbar-hide {
-ms-overflow-style: none;
scrollbar-width: none;
}

footer {
background: #FDFBF7;
color: var(--ink);
padding: 100px 0 40px;
position: relative;
}
footer::before {
content: '';
position: absolute;
top: 0;
left: 0;
right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, var(--saffron), transparent);
}
.foot-top {
display: grid;
grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
gap: 48px;
margin-bottom: 60px;
}
.foot-brand p {
color: rgba(26, 18, 8, 0.7);
font-size: 14px;
margin: 20px 0 24px;
max-width: 320px;
line-height: 1.6;
}
.socials {
display: flex;
gap: 12px;
}
.socials a {
width: 40px;
height: 40px;
border: 1px solid rgba(26, 18, 8, 0.15);
border-radius: 50%;
display: grid;
place-items: center;
color: var(--ink);
transition: all 0.3s ease;
}
.socials a:hover {
background: var(--saffron);
color: var(--ink);
border-color: var(--saffron);
transform: translateY(-3px);
}
.foot-col h5 {
font-family: 'Cormorant Garamond', serif;
font-style: italic;
font-size: 15px;
margin-bottom: 24px;
color: var(--saffron);
font-weight: 700;
letter-spacing: 0.05em;
}
.foot-col ul {
list-style: none;
padding: 0;
}
.foot-col li {
margin-bottom: 12px;
}
.foot-col a {
font-size: 14px;
color: rgba(26, 18, 8, 0.75);
transition: color 0.3s ease;
text-decoration: none;
}
.foot-col a:hover {
color: var(--ink);
}
.foot-bot {
border-top: 1px solid rgba(26, 18, 8, 0.1);
padding-top: 32px;
display: flex;
justify-content: space-between;
align-items: center;
color: rgba(26, 18, 8, 0.5);
font-size: 13px;
flex-wrap: wrap;
gap: 16px;
}
@media (max-width: 1024px) {
.foot-top { grid-template-columns: repeat(3, 1fr); }
.foot-brand { grid-column: span 3; margin-bottom: 20px; }
}
@media (max-width: 768px) {
.foot-top { grid-template-columns: repeat(2, 1fr); }
.foot-brand { grid-column: span 2; }
}


</style>
</head>
<body class="selection:bg-[#D4AF37]/30">
<app-navbar></app-navbar>
<header class="pt-32 pb-12 bg-[#F5F0E8] relative overflow-hidden">
<div class="absolute inset-0 opacity-[0.05] pointer-events-none">
<img src="pics/warli_pattern_1778230295803.png" class="w-full h-full object-cover" alt="pattern">
</div>
<div class="container mx-auto px-6 relative z-10 text-center max-w-4xl">
<div class="inline-block mb-6">
<span
class="font-sans text-[10px] uppercase tracking-[0.5em] text-[#D4AF37] font-bold border-b border-[#D4AF37]/30 pb-2">The
Masters Guild</span>
</div>
<h1 class="text-6xl md:text-8xl font-serif text-[#1A1208] mb-8 italic">Meet the <span
class="text-[#B5451B] not-italic">Makers</span></h1>
<p class="text-xl text-stone-600 font-sans leading-relaxed max-w-2xl mx-auto">
A sanctuary dedicated to the legendary master artisans keeping India's sacred traditions alive. Explore
their lineages, view their collections, and collaborate directly with them.
</p>
</div>
</header>
<section class="py-6 bg-white sticky top-[72px] z-40 border-b border-stone-100 shadow-sm">
<div class="container mx-auto px-6 flex flex-col lg:flex-row justify-between items-center gap-8">
<div class="search-bar flex items-center gap-4">
<span class="material-symbols-outlined text-stone-400">search</span>
<input type="text" id="artistSearch" placeholder="Search by name, state, or art form..."
class="bg-transparent border-none focus:ring-0 w-full text-sm font-sans placeholder-stone-300">
</div>
<div class="flex gap-2 overflow-x-auto no-scrollbar py-2 max-w-full custom-scrollbar">
<button class="filter-btn active" data-region="all">All Regions</button>
<button class="filter-btn" data-region="North">North</button>
<button class="filter-btn" data-region="South">South</button>
<button class="filter-btn" data-region="East">East</button>
<button class="filter-btn" data-region="West">West</button>
<button class="filter-btn" data-region="Central">Central</button>
</div>
</div>
</section>
<main class="py-24 container mx-auto px-6">
<div class="max-w-6xl mx-auto">
<div class="flex justify-between items-center mb-12">
<h2 class="font-serif text-2xl text-stone-800 italic">Guild <span class="text-[#D4AF37]">Roster</span>
</h2>
<p id="rosterCount" class="font-sans text-xs uppercase tracking-widest text-stone-400 font-bold">Showing
6 masters</p>
</div>
<div class="relative w-full group py-4">
<button id="slideLeftBtn"
class="absolute -left-4 md:-left-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-white rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center text-stone-600 hover:text-[#B5451B] transition-all opacity-0 group-hover:opacity-100 hover:scale-110 disabled:opacity-0 disabled:cursor-not-allowed">
<span class="material-symbols-outlined">arrow_back</span>
</button>
<div id="artistsGrid"
class="flex gap-12 overflow-x-auto pb-24 pt-12 no-scrollbar px-[10%] md:px-[30%] scroll-smooth items-center">
</div>
<button id="slideRightBtn"
class="absolute -right-4 md:-right-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-white rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-center text-stone-600 hover:text-[#B5451B] transition-all opacity-0 group-hover:opacity-100 hover:scale-110 disabled:opacity-0 disabled:cursor-not-allowed">
<span class="material-symbols-outlined">arrow_forward</span>
</button>
</div>
<div id="emptyState" class="hidden py-32 text-center">
<span class="material-symbols-outlined text-stone-200 text-6xl mb-4">person_search</span>
<h3 class="text-2xl font-serif text-stone-400">No master artisans found</h3>
<p class="text-stone-400 font-sans text-sm mt-2">Try adjusting your search criteria or choosing another
region.</p>
</div>
<div class="mt-16 text-center">
<a href="/"
class="inline-block bg-[#1A1208] text-white px-8 py-4 font-sans text-sm font-bold uppercase tracking-widest hover:bg-[#D4AF37] hover:text-[#1A1208] transition-all shadow-lg hover:-translate-y-1">
Explore more artists
</a>
</div>
</div>
</main>
<app-footer></app-footer>
<script>
let artistsData = [];

async function loadArtistsFromDB() {
    try {
        const res = await fetch('/api/artists/approved');
        const data = await res.json();
        if (data.success && data.artists) {
            artistsData = data.artists.map(artist => {
                const stateMap = {
                    bihar: "East", odisha: "East", west_bengal: "East",
                    maharashtra: "West", gujarat: "West", rajasthan: "West", goa: "West",
                    tamil_nadu: "South", karnataka: "South", kerala: "South", andhra_pradesh: "South", telangana: "South",
                    madhya_pradesh: "Central", chhattisgarh: "Central",
                    uttar_pradesh: "North", delhi: "North", punjab: "North", haryana: "North", himachal_pradesh: "North", jammu_kashmir: "North", uttarakhand: "North"
                };
                const locClean = (artist.location || '').toLowerCase().trim();
                let region = "East";
                for (let s in stateMap) {
                    if (locClean.includes(s.replace('_', ' '))) {
                        region = stateMap[s];
                        break;
                    }
                }
                
                const specVal = artist.specialization || "Art";
                const bgImg = "pics/madhubani_bg.png"; 
                const profileImg = artist.profilePic || "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=150";
                
                return {
                    name: artist.fullName,
                    art: specVal,
                    state: artist.location || "India",
                    region: region,
                    desc: "Master artisan creating timeless masterpieces.",
                    rating: "5.0",
                    bookings: "0",
                    bgImg: bgImg,
                    profileImg: profileImg,
                    email: artist.email
                };
            });
            if (typeof handleFilters === 'function') {
                handleFilters();
            }
        }
    } catch (e) {
        console.error("Failed to load artists from DB", e);
    }
}
loadArtistsFromDB();
let activeRegion = "all";
let currentRosterData = [];
let artistsGrid;
let slideLeftBtn;
let slideRightBtn;
let autoSlideTimer;
let currentIndex = 0;
let isHovered = false;
function scrollToCard(index, instant = false) {
if (!artistsGrid) return;
const cards = artistsGrid.querySelectorAll('.artisan-card');
if (!cards.length) return;

const clampedIndex = Math.max(0, Math.min(index, cards.length - 1));

const card = cards[clampedIndex];
const containerPaddingLeft = (artistsGrid.clientWidth / 2) - (card.offsetWidth / 2);
const scrollLeftPos = card.offsetLeft - containerPaddingLeft;

artistsGrid.scrollTo({ left: scrollLeftPos, behavior: instant ? 'auto' : 'smooth' });

cards.forEach((c, idx) => {
if (idx === clampedIndex) {
c.classList.add('active');
} else {
c.classList.remove('active');
}
});

currentIndex = clampedIndex;
const totalItems = cards.length / 3;

if (!instant) {
if (currentIndex >= totalItems * 2) {
setTimeout(() => {
scrollToCard(totalItems + (currentIndex % totalItems), true);
}, 800);
} else if (currentIndex < totalItems) {
setTimeout(() => {
scrollToCard(totalItems + (currentIndex % totalItems), true);
}, 800);
}
}
updateSlideButtons();
}
function updateSlideButtons() {
if (!artistsGrid || !slideLeftBtn || !slideRightBtn) return;
const cards = artistsGrid.querySelectorAll('.artisan-card');
if (!cards.length) return;
slideLeftBtn.disabled = false;
slideRightBtn.disabled = false;
}
function startAutoSlide() {
clearTimeout(window.resumeTimer);
stopAutoSlide();
autoSlideTimer = setInterval(() => {
if (!artistsGrid) return;
const cards = artistsGrid.querySelectorAll('.artisan-card');
if (!cards.length) return;
const next = (currentIndex + 1) % cards.length;
scrollToCard(next);
}, 3000);
}
function stopAutoSlide() {
if (autoSlideTimer) clearInterval(autoSlideTimer);
}
function renderRoster(data) {
const grid = document.getElementById('artistsGrid');
const countLabel = document.getElementById('rosterCount');
const empty = document.getElementById('emptyState');
currentRosterData = data;
if (data.length === 0) {
if (grid) grid.innerHTML = '';
if (countLabel) countLabel.textContent = 'Showing 0 masters';
if (empty) empty.classList.remove('hidden');
return;
}
if (empty) empty.classList.add('hidden');
if (countLabel) countLabel.textContent = `Showing ${data.length} master${data.length > 1 ? 's' : ''}`;
if (grid) {
grid.innerHTML = [...data, ...data, ...data].map((item, index) => `
<div class="artisan-card reveal w-[300px] md:w-[380px] flex-shrink-0 relative group/card cursor-pointer"
data-index="${index % data.length}"
onclick="handleCardClick(${index})">
<div class="h-44 bg-stone-900 relative overflow-hidden">
<img src="${item.bgImg}" class="w-full h-full object-cover opacity-80 hover:scale-105 transition-transform duration-700" alt="${item.art}">
<img src="${item.profileImg}" class="w-20 h-20 rounded-full border-4 border-white absolute -bottom-10 left-6 object-cover shadow-lg z-10" alt="${item.name}">
</div>
<div class="pt-14 p-6 relative bg-white">
<h3 class="font-serif text-2xl text-[#1A1208] mb-3">${item.name}</h3>
<div class="flex gap-2 mb-4">
<span class="bg-[#B5451B] text-white text-[9px] font-bold px-2 py-1 rounded-full uppercase tracking-wider">${item.state}</span>
<span class="border border-stone-300 text-stone-500 text-[9px] font-bold px-2 py-1 rounded-full uppercase tracking-wider">${item.art}</span>
</div>
<div class="flex items-center gap-1 mb-4 text-[#D4AF37] text-xs font-sans">
★★★★★ <span class="text-stone-400 font-sans ml-1 text-[11px]">${item.rating} · ${item.bookings} bookings</span>
</div>
<p class="text-stone-600 font-sans text-sm mb-6 h-12 leading-relaxed">${item.desc}</p>
<div class="flex gap-3 pt-2 border-t border-stone-100">
<button onclick="event.stopPropagation(); window.location.href='/?artist=' + encodeURIComponent('${item.email}')" class="flex-1 border border-stone-300 text-[#1A1208] text-[10px] font-bold uppercase tracking-wider py-3 hover:bg-stone-50 transition-colors">View Portfolio</button>
<button onclick="event.stopPropagation(); handleBookArtist('${item.email}')" class="flex-1 bg-[#1A1208] text-white text-[10px] font-bold uppercase tracking-wider py-3 hover:bg-[#D4AF37] hover:text-[#1A1208] transition-colors">Book Now →</button>
</div>
</div>
</div>
`).join('');
}

currentIndex = data.length;
stopAutoSlide();
setTimeout(() => {
scrollToCard(currentIndex, true);
startAutoSlide();
}, 100);
const cards = grid ? grid.querySelectorAll('.reveal') : [];
cards.forEach((el, i) => {
setTimeout(() => el.classList.add('in'), i * 60);
});

setTimeout(() => {
if (grid) grid.dispatchEvent(new Event('scroll'));
}, 100);
}

const searchInput = document.getElementById('artistSearch');
const filterButtons = document.querySelectorAll('.filter-btn');
function handleFilters() {
let filtered = [...artistsData];
const query = searchInput.value.toLowerCase();

if (query) {
filtered = filtered.filter(item =>
item.name.toLowerCase().includes(query) ||
item.state.toLowerCase().includes(query) ||
item.art.toLowerCase().includes(query) ||
item.region.toLowerCase().includes(query) ||
(item.desc && item.desc.toLowerCase().includes(query))
);
}

if (activeRegion !== "all") {
filtered = filtered.filter(item => item.region === activeRegion);
}
renderRoster(filtered);
}
searchInput.addEventListener('input', handleFilters);
filterButtons.forEach(btn => {
btn.addEventListener('click', (e) => {
filterButtons.forEach(b => b.classList.remove('active'));
btn.classList.add('active');
activeRegion = btn.getAttribute('data-region');
handleFilters();
});
});

document.addEventListener('DOMContentLoaded', () => {
artistsGrid = document.getElementById('artistsGrid');
slideLeftBtn = document.getElementById('slideLeftBtn');
slideRightBtn = document.getElementById('slideRightBtn');
renderRoster(artistsData);
if (slideLeftBtn && slideRightBtn && artistsGrid) {
slideLeftBtn.addEventListener('click', () => {
stopAutoSlide();
scrollToCard(currentIndex - 1);
startAutoSlide();
});
slideRightBtn.addEventListener('click', () => {
stopAutoSlide();
scrollToCard(currentIndex + 1);
startAutoSlide();
});
artistsGrid.addEventListener('mouseenter', () => {
isHovered = true;
stopAutoSlide();
});
artistsGrid.addEventListener('mouseleave', () => {
isHovered = false;
startAutoSlide();
});
window.addEventListener('resize', () => {
scrollToCard(currentIndex, true);
});
}
window.handleCardClick = function (index) {
stopAutoSlide();
const cards = artistsGrid.querySelectorAll('.artisan-card');
const clickedCard = cards[index];
if (clickedCard.classList.contains('active')) {
const item = currentRosterData[index % currentRosterData.length];
if (item && item.email) {
window.location.href = `/?artist=${encodeURIComponent(item.email)}`;
return;
}
}
currentIndex = index;
scrollToCard(index);

startAutoSlide();
};

window.handleBookArtist = function (artistEmail) {
if (localStorage.getItem('userLoggedIn') === 'true') {
window.location.href = '/';
} else if (localStorage.getItem('artistLoggedIn') === 'true') {
alert('Please sign in with an Art Collector account to book an artist.');
localStorage.removeItem('artistLoggedIn');
localStorage.removeItem('artistEmail');
localStorage.removeItem('currentUser');
window.location.href = '/';
} else {
window.location.href = '/';
}
};
});

const revealObserver = new IntersectionObserver((entries) => {
entries.forEach(entry => {
if (entry.isIntersecting) {
entry.target.classList.add('in');
}
});
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
</script>
<script src="https://unpkg.com/lucide@latest"></script>
<script>
lucide.createIcons();
</script>
<script src="content-loader.js"></script>
</body>
</html>