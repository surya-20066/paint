<script>
let allApprovedArtists = [];

async function fetchArtists() {
    try {
        const res = await fetch('/api/artists/approved');
        const data = await res.json();
        if (data.success) {
            allApprovedArtists = data.artists;
        }
    } catch (e) {
        console.error('Failed to fetch artists', e);
    }
}

const fallbackRegion = "Bihar";
async function requestLocation() {
const btn = document.getElementById('location-btn');
const text = document.getElementById('location-text');
btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-sm">sync</span> Accessing...';

await fetchArtists();

if (navigator.geolocation) {
navigator.geolocation.getCurrentPosition(
async (position) => {
const lat = position.coords.latitude;
const lon = position.coords.longitude;
try {

const response = await fetch(`https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${lat}&longitude=${lon}&localityLanguage=en`);
const data = await response.json();

const state = data.principalSubdivision || data.city || "Your Region";

updateDashboard(state, false, state);
} catch (error) {
console.warn("Geocoding error:", error);
updateDashboard(fallbackRegion, true);
}
},
(error) => {
console.warn("Location error:", error);
let msg = "Access Denied";
if (error.code === 1) msg = "Location Blocked";
text.innerHTML = `<p class="text-xs text-red-400 font-bold uppercase tracking-widest">${msg}</p><p class="text-sm font-bold">Showing Featured Artists</p>`;
updateDashboard(fallbackRegion, true);
}
);
} else {
updateDashboard(fallbackRegion, true);
}
}

function updateDashboard(region, isFallback = false, realStateName = "") {
const regionSpan = document.getElementById('current-region');
const locationText = document.getElementById('location-text');
const locationBtn = document.getElementById('location-btn');
const grid = document.getElementById('artists-grid');
const displayRegion = realStateName || region;
regionSpan.innerText = displayRegion;
locationText.innerHTML = `
<p class="text-xs text-[#D4AF37] font-bold uppercase tracking-widest">${isFallback ? 'Default Region' : 'Location Verified'}</p>
<p class="text-sm font-bold">${displayRegion}, India</p>
`;
locationBtn.classList.add('hidden');

// Filter artists by region, fallback to any if none match
let artists = allApprovedArtists.filter(a => a.location.toLowerCase().includes(region.toLowerCase()));
let isFeaturedFallback = false;
if (artists.length === 0 && allApprovedArtists.length > 0) {
    artists = allApprovedArtists.slice(0, 8); // show featured artists
    isFeaturedFallback = true;
}
if (isFeaturedFallback) {
    regionSpan.innerText = 'All Regions';
    document.querySelector('#artists-section p').textContent = 'No artists found in ' + displayRegion + ' yet. Showing featured artists from across India.';
}

grid.innerHTML = '';
if (artists.length === 0) {
    grid.innerHTML = '<p class="text-stone-500 col-span-full">No artists found in your region yet.</p>';
    return;
}

artists.slice(0, 8).forEach((artist, index) => {
const img = artist.profilePic || "https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&q=80&w=400";
const rating = 4.8;
const card = `
<div class="warli-border group artist-card rounded-xl overflow-hidden bg-white shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 opacity-0 animate-fade-in" style="animation-delay: ${index * 100}ms; animation-fill-mode: forwards;">
<div class="h-48 overflow-hidden relative">
<img src="${img}" alt="${artist.fullName}" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110">
</div>
<div class="p-6">
<div class="flex justify-between items-start mb-2">
<h4 class="text-lg font-serif text-[#1A1208] leading-tight">${artist.fullName}</h4>
<div class="flex items-center gap-1 text-[#D4AF37]">
<span class="material-symbols-outlined text-xs">star</span>
<span class="text-[10px] font-bold">${rating}</span>
</div>
</div>
<p class="text-[10px] text-stone-400 uppercase tracking-widest font-bold mb-4">${artist.specialization} Master · ${artist.location}</p>
<button onclick="window.location.href='/payment?item=' + encodeURIComponent('Commission: ${artist.fullName} (${artist.specialization})') + '&price=5000'" class="w-full py-2 bg-[#B5451B] text-white text-[9px] font-bold uppercase tracking-widest rounded hover:bg-[#D4AF37] transition-all flex items-center justify-center gap-1">Hire Artist <span class="material-symbols-outlined text-[12px]">arrow_forward</span></button>
</div>
</div>
`;
grid.innerHTML += card;
});
}

async function fetchUserPayments() {
    try {
        const res = await fetch('/api/user/payments');
        const data = await res.json();
        const container = document.getElementById('commissions-container');
        const countSpan = document.getElementById('active-commissions-count');
        
        if (data.success && data.payments && data.payments.length > 0) {
            countSpan.textContent = `${data.payments.length} Ongoing`;
            container.innerHTML = '';
            data.payments.forEach(payment => {
                const itemHTML = `
                <div class="flex items-center gap-4 p-4 bg-stone-50 rounded-xl hover:bg-stone-100 transition-all border border-transparent hover:border-stone-200 cursor-pointer">
                    <div class="w-12 h-12 bg-orange-100 text-[#B5451B] rounded-lg flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined">palette</span>
                    </div>
                    <div class="flex-1">
                        <div class="text-sm font-bold">${payment.itemName.replace('Commission: ', '')}</div>
                        <div class="text-xs text-stone-500">Status: ${payment.status}</div>
                    </div>
                    <div class="text-right">
                        <div class="text-xs font-bold text-orange-600">₹${payment.amount}</div>
                    </div>
                </div>
                `;
                container.innerHTML += itemHTML;
            });
        } else {
            countSpan.textContent = '0 Ongoing';
            container.innerHTML = '<p class="text-stone-500 text-sm p-4">No active commissions or bookings yet.</p>';
        }
    } catch (e) {
        console.error('Failed to fetch payments', e);
    }
}

function updateTrending() {
    const trendingContainer = document.getElementById('trending-container');
    if(!trendingContainer) return;
    trendingContainer.innerHTML = '';
    
    if (allApprovedArtists.length === 0) {
        trendingContainer.innerHTML = '<p class="text-stone-500 text-sm p-4">More artists joining soon.</p>';
        return;
    }
    
    // Pick 3 random artists for trending
    const shuffled = [...allApprovedArtists].sort(() => 0.5 - Math.random());
    const trending = shuffled.slice(0, 3);
    
    trending.forEach(artist => {
        const item = `
        <div class="flex items-center gap-4 group cursor-pointer" onclick="window.location.href='/explore'">
            <div class="w-16 h-16 rounded-xl overflow-hidden border-2 border-stone-200 group-hover:border-[#D4AF37] transition-all bg-stone-100 flex items-center justify-center">
                <img src="${artist.profilePic || 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&q=80&w=100'}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all">
            </div>
            <div>
                <div class="text-sm font-bold group-hover:text-[#B5451B]">${artist.specialization}</div>
                <div class="text-[10px] text-stone-400 uppercase tracking-widest">${artist.location}</div>
            </div>
        </div>
        `;
        trendingContainer.innerHTML += item;
    });
}

const style = document.createElement('style');
style.innerHTML = `
@keyframes fadeIn {
from { opacity: 0; transform: translateY(20px); }
to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
animation: fadeIn 0.6s ease-out forwards;
}
`;
document.head.appendChild(style);

window.addEventListener('load', async () => {
    await requestLocation();
    await fetchUserPayments();
    updateTrending();
});

document.addEventListener('DOMContentLoaded', () => {
const menuBtns = document.querySelectorAll('.mobile-menu-btn-toggle');
const sidebar = document.querySelector('aside');
if (sidebar) {
const closeBtn = document.createElement('button');
closeBtn.className = 'lg:hidden absolute top-4 right-4 text-stone-900 hover:text-[#B5451B] p-2 z-50';
closeBtn.innerHTML = '<span class="material-symbols-outlined text-3xl">close</span>';
sidebar.appendChild(closeBtn);

sidebar.classList.add('transition-all', 'duration-300');

menuBtns.forEach(btn => {
btn.addEventListener('click', (e) => {
e.stopPropagation();
sidebar.classList.remove('hidden');
sidebar.classList.add('fixed', 'inset-y-0', 'left-0', 'z-[100]', 'shadow-2xl', 'flex');
});
});

closeBtn.addEventListener('click', () => {
sidebar.classList.add('hidden');
sidebar.classList.remove('fixed', 'inset-y-0', 'left-0', 'z-[100]', 'shadow-2xl', 'flex');
});

document.addEventListener('click', (e) => {
if (window.innerWidth < 1024 && sidebar.classList.contains('fixed')) {
if (!sidebar.contains(e.target) && ![...menuBtns].some(btn => btn.contains(e.target))) {
sidebar.classList.add('hidden');
sidebar.classList.remove('fixed', 'inset-y-0', 'left-0', 'z-[100]', 'shadow-2xl', 'flex');
}
}
});
}
});
</script>
<script>
function logoutArtist() {
if (confirm('Sign out of your studio?')) {
localStorage.removeItem('artistLoggedIn');
localStorage.removeItem('artistEmail');
localStorage.removeItem('currentUser');
window.location.href = '/';
}
}
let _cu = {};
try {
  _cu = JSON.parse(localStorage.getItem('currentUser') || '{}');
  if (typeof _cu !== 'object' || Array.isArray(_cu)) _cu = {};
} catch(e) {
  _cu = {};
}
const nameEl = document.getElementById('sidebar-artist-name');
if (nameEl) nameEl.textContent = _cu.fullName || _cu.email || 'Artist';
</script>
<script src="content-loader.js"></script>
</body>
</html>