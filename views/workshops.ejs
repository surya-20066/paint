<script>
function bookEvent(price, eventName) {
  const isLoggedIn = localStorage.getItem('userLoggedIn') === 'true';
  if (isLoggedIn) {
    window.location.href = `/?price=${price}&item=${encodeURIComponent(eventName)}`;
  } else {
    // Save intended destination
    localStorage.setItem('redirectAfterLogin', `/?price=${price}&item=${encodeURIComponent(eventName)}`);
    window.location.href = '/?error=auth';
  }
}
</script>
